{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "绨络",
  "version": "0.1.0-preview.1",
  "identifier": "com.tauri-app.ltypet",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "width": 400,
        "height": 500,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false
      },
      {
        "label": "settings",
        "url": "settings.html",
        "title": "绨络设置",
        "width": 480,
        "height": 520,
        "decorations": true,
        "resizable": true,
        "skipTaskbar": false,
        "visible": false
      },
      {
        "label": "chat",
        "url": "chat.html",
        "title": "与小洛宝对话",
        "width": 520,
        "height": 680,
        "minWidth": 380,
        "minHeight": 480,
        "decorations": true,
        "resizable": true,
        "skipTaskbar": false,
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "shortDescription": "绨络 Tylpet——轻量、可扩展的 Windows 桌面伙伴",
    "longDescription": "绨络 Tylpet 是一个具有透明窗口、桌面交互、番茄钟、可选模型对话和受控插件能力的 Windows 桌面伙伴；小洛宝是当前内置角色。",
    "copyright": "Copyright © 2026 Tylpet contributors",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
